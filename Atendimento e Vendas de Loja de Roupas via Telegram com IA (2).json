        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": \"Classifique a mensagem do cliente e responda APENAS com JSON válido.\\n\\nFormato:\\n{\\n  \\\"status_atendimento\\\": \\\"saudacao\\\" | \\\"listar_produtos\\\" | \\\"buscar_produto\\\" | \\\"pedido\\\" | \\\"suporte\\\",\\n  \\\"produto\\\": \\\"\\\",\\n  \\\"resposta_ia\\\": \\\"\\\",\\n  \\\"etapa_funil\\\": \\\"atendimento\\\"\\n}\\n\\nMensagem do cliente: {{$json.mensagem_cliente}}\\n\\nNão escreva nada além do JSON.\"\n        }\n      ]\n    }\n  ]\n}",
        "options": {}
      },
      "id": "964d8606-a623-4cb9-aded-95c35ebf967b",
      "name": "Analisar Intenção com Gemini",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
