    {
      "parameters": {
        "jsCode": "const entrada = $input.first().json;\n\nlet texto = \"\";\n\nif (\n  entrada &&\n  entrada.candidates &&\n  entrada.candidates[0] &&\n  entrada.candidates[0].content &&\n  entrada.candidates[0].content.parts &&\n  entrada.candidates[0].content.parts[0] &&\n  entrada.candidates[0].content.parts[0].text\n) {\n  texto = entrada.candidates[0].content.parts[0].text;\n}\n\nif (!texto) {\n  return [\n    {\n      json: {\n        status_atendimento: \"suporte\",\n        produto: \"\",\n        resposta_ia: \"Desculpe, ocorreu um erro ao processar sua mensagem.\",\n        etapa_funil: \"erro\"\n      }\n    }\n  ];\n}\n\n// limpar marcações comuns\ntexto = texto.split(\"json\").join(\"\");\ntexto = texto.split(\"\").join(\"\");\ntexto = texto.trim();\n\n// remover \"json\" no começo, se vier\nif (texto.toLowerCase().startsWith(\"json\")) {\n  texto = texto.slice(4).trim();\n}\n\n// tentar extrair só o objeto JSON\nconst inicio = texto.indexOf(\"{\");\nconst fim = texto.lastIndexOf(\"}\");\n\nif (inicio !== -1 && fim !== -1 && fim > inicio) {\n  texto = texto.slice(inicio, fim + 1);\n}\n\nlet dados;\n\ntry {\n  dados = JSON.parse(texto);\n} catch (e) {\n  dados = {\n    status_atendimento: \"suporte\",\n    produto: \"\",\n    resposta_ia: texto,\n    etapa_funil: \"atendimento\"\n  };\n}\n\nconst statusBruto = String(dados.status_atendimento || dados.intencao || \"\")\n  .toLowerCase()\n  .normalize(\"NFD\")\n  .replace(/[\\u0300-\\u036f]/g, \"\")\n  .trim();\n\nconst produtoBruto = String(dados.produto || \"\").trim();\nconst respostaBruta = String(dados.resposta_ia || dados.resposta || \"\").trim();\n\nlet status_atendimento = \"suporte\";\n\nif ([\"saudacao\", \"oi\", \"ola\", \"cumprimento\"].includes(statusBruto)) {\n  status_atendimento = \"saudacao\";\n} else if (\n  [\"listar_produtos\", \"listar\", \"ver_produtos\", \"mostrar_produtos\", \"catalogo\"].includes(statusBruto)\n) {\n  status_atendimento = \"listar_produtos\";\n} else if (\n  [\"buscar_produto\", \"produto\", \"consultar_produto\", \"ver_produto\"].includes(statusBruto)\n) {\n  status_atendimento = produtoBruto ? \"buscar_produto\" : \"listar_produtos\";\n} else if (\n  [\"pedido\", \"comprar\", \"fazer_pedido\", \"realizar_pedido\"].includes(statusBruto)\n) {\n  status_atendimento = \"pedido\";\n}\n\nlet resposta_ia = respostaBruta;\n\nif (!resposta_ia) {\n  if (status_atendimento === \"saudacao\") {\n    resposta_ia = \"Olá! Como posso te ajudar hoje?\";\n  } else if (status_atendimento === \"listar_produtos\") {\n    resposta_ia = \"Claro! Vou te mostrar alguns produtos disponíveis.\";\n  } else if (status_atendimento === \"buscar_produto\") {\n    resposta_ia = \"Vou verificar esse produto para você.\";\n  } else if (status_atendimento === \"pedido\") {\n    resposta_ia = \"Perfeito! Vou registrar seu pedido.\";\n  } else {\n    resposta_ia = \"Não entendi muito bem. Você quer ver produtos, fazer um pedido ou falar com o atendimento?\";\n  }\n}\n\nreturn [\n  {\n    json: {\n      status_atendimento: status_atendimento,\n      produto: produtoBruto,\n      resposta_ia: resposta_ia,\n      etapa_funil: String(dados.etapa_funil || \"atendimento\").trim()\n    }\n  }\n];"
      },
