    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const entrada = $json;\nconst mensagem = String(entrada.mensagem_cliente || \"\").toLowerCase();\n\nlet produto = \"\";\n\nif (mensagem.includes(\"tenis\") || mensagem.includes(\"tênis\")) {\n  produto = \"Tênis\";\n} else if (mensagem.includes(\"camisa\")) {\n  produto = \"Camisa\";\n} else if (mensagem.includes(\"comida\")) {\n  produto = \"Comida\";\n} else {\n  produto = entrada.produto || \"Produto não identificado\";\n}\n\nlet grupo = \"\";\nif (produto === \"Tênis\") {\n  grupo = \"calçados\";\n} else if (produto === \"Camisa\") {\n  grupo = \"roupas\";\n} else if (produto === \"Comida\") {\n  grupo = \"alimentos\";\n}\n\nlet cor = \"\";\nif (mensagem.includes(\"preto\")) {\n  cor = \"preto\";\n} else if (mensagem.includes(\"branco\")) {\n  cor = \"branco\";\n} else if (mensagem.includes(\"azul\")) {\n  cor = \"azul\";\n} else if (mensagem.includes(\"vermelho\")) {\n  cor = \"vermelho\";\n}\n\nreturn {\n  json: {\n    id_loja: entrada.id_loja || \"loja_001\",\n    id_pedido: Date.now().toString(),\n    id_cliente: entrada.id_cliente || \"\",\n    cliente: entrada.cliente || \"\",\n    id_do_chat: entrada.id_do_chat || entrada.id_cliente || \"\",\n    mensagem_cliente: entrada.mensagem_cliente || \"\",\n\n    id_produto: \"\",\n    produto: produto,\n    produto_nome: produto,\n    grupo: grupo,\n    cor: cor,\n\n    quantidade: 1,\n    valor_total: 0,\n\n    forma_pagamento: \"pendente\",\n    status_pedido: \"novo\",\n    status_pagamento: \"pendente\",\n\n    endereco_entrega: \"aguardando_endereco\",\n    codigo_rastreio: \"aguardando_envio\",\n\n    status_atendimento: \"pedido\",\n    etapa_funil: \"pedido\",\n\n    dados: entrada.dados || \"\",\n    hora: entrada.hora || \"\"\n  }\n};"
      },
