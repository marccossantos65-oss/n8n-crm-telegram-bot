    {
      "parameters": {
        "jsCode": "const input = $json;\n\n// Detectar origem\nlet origem = \"unknown\";\nlet chat_id = \"\";\nlet cliente = \"\";\nlet username = \"\";\nlet mensagem_cliente = \"\";\n\n// TELEGRAM\nif (input.message) {\n  origem = \"telegram\";\n  chat_id = input.message.chat?.id ?? \"\";\n  cliente = input.message.from?.first_name ?? \"\";\n  username = input.message.from?.username ?? \"\";\n  mensagem_cliente = input.message.text ?? \"\";\n}\n\n// WHATSAPP (estrutura comum APIs)\nelse if (input.contacts || input.messages) {\n  origem = \"whatsapp\";\n  chat_id = input.contacts?.[0]?.wa_id ?? \"\";\n  cliente = input.contacts?.[0]?.profile?.name ?? \"\";\n  mensagem_cliente = input.messages?.[0]?.text?.body ?? \"\";\n}\n\n// INSTAGRAM / FACEBOOK (Meta Webhook)\nelse if (input.entry) {\n  origem = \"instagram\";\n  const msg = input.entry?.[0]?.messaging?.[0] ?? {};\n  chat_id = msg.sender?.id ?? \"\";\n  mensagem_cliente = msg.message?.text ?? \"\";\n  cliente = \"cliente_instagram\";\n}\n\n// ID cliente\nconst id_cliente = `cli_${chat_id}`;\n\n// ID loja (estrutura SaaS futura)\nconst id_loja = \"loja_001\";\n\n// Data e hora\nconst agora = new Date();\nconst data = agora.toISOString().split(\"T\")[0];\nconst hora = agora.toTimeString().split(\" \")[0];\n\n// Retorno padronizado\nreturn [{\n  json: {\n\n    id_loja,\n\n    id_cliente,\n    cliente,\n    chat_id,\n    username,\n\n    mensagem_cliente,\n    origem,\n\n    data,\n    hora,\n\n    etapa_funil: \"novo_contato\",\n    produto_interesse: \"\",\n    valor_estimado: \"\",\n    status: \"novo\"\n\n  }\n}];"
      },
